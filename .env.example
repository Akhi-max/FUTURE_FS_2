# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local MongoDB (default)
MONGO_URI=mongodb://localhost:27017/mini-crm

# MongoDB Atlas (cloud) — replace with your connection string
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/mini-crm?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=24h
